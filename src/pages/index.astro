---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = posts.slice(0, 5);
---

<BaseLayout title="daniel ho">
  <section>
    <p>
      I build software, write about what I'm learning, and make pottery when I'm
      away from the screen.
    </p>
  </section>

  <section>
    <h2>Writing</h2>
    <ul class="post-list">
      {
        recentPosts.map((post) => (
          <li>
            <a href={`/writing/${post.id}/`}>
              <span>{post.data.title}</span>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </a>
          </li>
        ))
      }
    </ul>
    {posts.length > 5 && <a href="/blog">all posts &rarr;</a>}
  </section>

  <section>
    <h2>Work</h2>
    <ul class="work-list">
      <li>
        <a href="https://anime.com/">Anime</a>
        <span>LLM-powered news aggregation, streaming, licensing, and social for anime fans.</span>
      </li>
      <li>
        <a href="https://azuki.com/">Azuki</a>
        <span>Anime NFT brand and community.</span>
      </li>
      <li>
        <a href="https://koop.xyz/">Koop</a>
        <span>On-chain rails for creators and communities.</span>
      </li>
      <li>
        <a href="https://flexport.com/">Flexport</a>
        <span>Microservices, DevOps, Kubernetes Dev Environments. Shipment domain modeling with an event driven architecture.</span>
      </li>
      <li>
        <a href="https://facebook.com/">Meta</a>
        <span>Messenger infrastructure. Profile and stories processing unit.</span>
      </li>
      <li>
        <a href="https://salesforce.com/">Salesforce</a>
        <span>File streaming service for real-time collaboration.</span>
      </li>
      <li>
        <a href="https://jpl.nasa.gov/">NASA</a>
        <span>Deep learning applied to CNN noise detection.</span>
      </li>
      <li>
        <a href="https://www.usc.edu/">USC</a>
        <span>Discrete Math and Algorithms. Researcher evaluating pre-trained language models (BERT, GPT-2) for commonsense reasoning against textual logic perturbations.</span>
      </li>
    </ul>
  </section>

  <section>
    <h2>Publications</h2>
    <ul class="work-list">
      <li>
        <a href="https://arxiv.org/abs/2005.00782">RICA: Evaluating Robust Inference Capabilities Based on Commonsense Axioms</a>
      </li>
    </ul>
  </section>

  <section>
    <h2>Contact</h2>
    <div class="contact">
      <a href="mailto:danielho54@gmail.com">email</a>
      <a href="https://github.com/donutdaniel" target="_blank">
        <img class="media-icon" src="/icons/media/github.svg" alt="GitHub" />
      </a>
      <a href="https://x.com/donutdho" target="_blank">
        <img class="media-icon" src="/icons/media/x.svg" alt="X" />
      </a>
      <a href="https://linkedin.com/in/danielho54" target="_blank">
        <img class="media-icon" src="/icons/media/linkedin.svg" alt="LinkedIn" />
      </a>
    </div>
  </section>
</BaseLayout>
